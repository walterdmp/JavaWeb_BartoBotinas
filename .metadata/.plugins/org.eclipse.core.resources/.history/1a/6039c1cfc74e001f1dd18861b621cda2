<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<link rel="stylesheet" href="css/estilo.css">
<meta charset="UTF-8">
<title>Cadastrar Produto</title>
</head>
<body>
	<nav class="bartoNav">
		<ul>
			<li><a href="home.jsp">Home</a></li>
			<li><a href="cadastrarCliente.jsp">Cliente</a></li>
			<li><a href="cadastrarFornecedor.jsp">Fornecedor</a></li>
			<li><a href="cadastrarPedidoCliente.jsp">Pedido Cliente</a></li>
			<li><a href="cadastrarPedidoFornecedor.jsp">Pedido Fornecedor</a></li>
			<li><a href="cadastrarProdutos.jsp">Produtos</a></li>
		</ul>
	</nav>
	<main class="bartoMain">
		<div class="produtoForm">
			<h1>Cadastrar Produto</h1>
			<form action="ProdutoServlet" method="post">
				<div>
					<label for="nome"><strong>Nome:</strong></label>
					<input type="text" id="nome" name="nome" required>
				</div>
				<div>
					<label for="preco"><strong>Preço:</strong></label>
					<input type="number" step="0.01" id="preco" name="preco" required>
				</div>
				<div>
					<label for="estoque"><strong>Estoque:</strong></label>
					<input type="number" id="estoque" name="estoque" required>
				</div>
				<div>
					<label for="fornecedor"><strong>Fornecedor:</strong></label>
					<select id="fornecedor" name="idFornecedor" required>
						<option value="">Selecione um fornecedor</option>
						<c:forEach var="fornecedor" items="${fornecedores}">
							<option value="${fornecedor[0]}">${fornecedor[1]}</option>
						</c:forEach>
					</select>
				</div>
				<div>
					<input id="bartoButton" type="submit" value="Cadastrar Produto">
				</div>
			</form>
		</div>
	</main>
</body>
</html>
