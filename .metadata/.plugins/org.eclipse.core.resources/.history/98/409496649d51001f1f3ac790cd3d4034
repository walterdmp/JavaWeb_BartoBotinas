<%@ page language="java" contentType="text/html; charset=UTF-8"
	pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<link rel="stylesheet" href="css/estilo.css">
<meta charset="UTF-8">
<title>Bartô Botinas - Fornecedores</title>
</head>
<body>
	<nav class="bartoNav">
		<ul>
			<li><a href="home.jsp">Home</a></li>
			<li><a href="cadastrarCaixa.jsp">Caixa</a></li>
			<li><a href="cadastrarCliente.jsp">Cliente</a></li>
			<li><a href="cadastrarFornecedor.jsp">Fornecedor</a></li>
			<li><a href="cadastrarFuncionario.jsp">Funcionário</a></li>
			<li><a href="cadastrarPedidoCliente.jsp">Pedido Cliente</a></li>
			<li><a href="cadastrarPedidoFornecedor.jsp">Pedido
					Fornecedor</a></li>
			<li><a href="cadastrarProdutos.jsp">Produtos</a></li>
		</ul>
	</nav>
	<main class="bartoMain">
		<form action="cadastrarFornecedorController" method="post"
			class="bartoForm">
			<div>
				<label for="nome"><strong>Nome:</strong></label> <input type="text"
					id="nome" name="nome" placeholder="Nome do fornecedor"
					pattern="[A-Za-z\s]+" title="Somente letras" required>
			</div>

			<div>
				<label for="cnpj"><strong>CNPJ:</strong></label> <input type="text"
					id="cnpj" name="cnpj" placeholder="CNPJ do fornecedor"
					pattern="\d+" title="Somente números" required>
			</div>
			<div>
				<label for="telefone"><strong>Telefone:</strong></label> <input
					type="text" id="telefone" name="telefone"
					placeholder="Telefone do fornecedor" pattern="\d+"
					title="Somente números" required>
			</div>

			<div>
				<label for="email"><strong>E-mail:</strong></label> <input
					type="email" id="email" name="email"
					placeholder="Email do fornecedor" required>
			</div>
			<br>
			<div>
				<input id="bartoButton" type="submit" name="salvar"
					value="Cadastrar Fornecedor">
			</div>
		</form>
	</main>
</body>
</html>
