	<main class="bartoMain">
		<form action="cadastrarPedidoFornecedor" method="post" class="bartoForm">
			<div>
				<label for="idFornecedor"><strong>ID do Fornecedor:</strong></label>
				<input type="text" id="idFornecedor" name="idFornecedor" placeholder="ID do fornecedor" required>
			</div>
			<div>
				<label for="idProduto"><strong>ID do Produto:</strong></label>
				<input type="text" id="idProduto" name="idProduto" placeholder="ID do produto" required>
			</div>
			<div>
				<label for="quantidade"><strong>Quantidade:</strong></label>
				<input type="number" id="quantidade" name="quantidade" placeholder="Quantidade do produto" required>
			</div>
			<br>
			<div>
				<input id="bartoButton" type="submit" name="salvar" value="Registrar Pedido">
			</div>
		</form>
	</main>
